{
    "name": "@adguard/filters-downloader",
    "version": "2.4.4",
    "description": "Downloads filter source files",
    "main": "dist/index.js",
    "browser": "dist/index.browser.js",
    "types": "dist/types/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "default": "./dist/index.js"
        },
        "./browser": {
            "types": "./dist/types/index.browser.d.ts",
            "default": "./dist/index.browser.js"
        }
    },
    "scripts": {
        "prebuild": "pnpm rimraf dist && pnpm build:types",
        "build": "rollup -c rollup.config.ts --configPlugin typescript && pnpm build:version",
        "watch": "rollup -c rollup.config.ts --configPlugin typescript --watch",
        "build:version": "ts-node scripts/build-txt.ts",
        "build:types": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly --outdir dist/types",
        "test": "ts-node _qunit_tests_/testrunner.ts && vitest run",
        "test:qunit": "ts-node _qunit_tests_/testrunner.ts",
        "test:vitest": "vitest run",
        "lint": "pnpm lint:code && pnpm lint:types && pnpm lint:md",
        "lint:code": "eslint --cache .",
        "lint:types": "tsc --noEmit",
        "lint:md": "markdownlint .",
        "lint-staged": "lint-staged",
        "prepare": "husky install",
        "increment": "pnpm version patch --no-git-tag-version",
        "tgz": "pnpm pack --out filters-downloader.tgz"
    },
    "lint-staged": {
        "{src,scripts,test}/**/*.{js,ts}": [
            "eslint --cache .",
            "tsc-files --noEmit"
        ],
        "**/*.md": [
            "markdownlint"
        ]
    },
    "engines": {
        "node": ">=20"
    },
    "author": "AdGuard",
    "license": "GPL-3.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AdguardTeam/FiltersDownloader.git"
    },
    "bugs": {
        "url": "https://github.com/AdguardTeam/FiltersDownloader/issues"
    },
    "homepage": "https://github.com/AdguardTeam/FiltersDownloader#readme",
    "dependencies": {
        "@adguard/diff-builder": "1.1.4",
        "axios": "1.15.0",
        "crypto-js": "4.2.0"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "25.0.7",
        "@rollup/plugin-json": "6.0.1",
        "@rollup/plugin-node-resolve": "15.2.3",
        "@rollup/plugin-typescript": "11.1.5",
        "@types/crypto-js": "4.2.2",
        "@types/express": "4.17.21",
        "@types/mock-fs": "4.13.4",
        "@types/node": "20.9.2",
        "@types/qunit": "2.19.9",
        "@typescript-eslint/eslint-plugin": "6.11.0",
        "@typescript-eslint/parser": "6.11.0",
        "eslint": "8.50.0",
        "eslint-config-airbnb-base": "15.0.0",
        "eslint-config-airbnb-typescript": "17.1.0",
        "eslint-plugin-import": "2.29.0",
        "eslint-plugin-import-newlines": "1.3.4",
        "eslint-plugin-jsdoc": "46.9.0",
        "express": "4.18.2",
        "husky": "8.0.3",
        "lint-staged": "14.0.1",
        "markdownlint": "0.40.0",
        "markdownlint-cli": "0.48.0",
        "mock-fs": "5.5.0",
        "nock": "13.4.0",
        "node-qunit": "2.0.0",
        "rimraf": "5.0.5",
        "rollup": "4.9.1",
        "rollup-plugin-cleanup": "3.2.1",
        "ts-node": "10.9.1",
        "tsc-files": "1.1.4",
        "tslib": "2.6.2",
        "typescript": "5.3.3",
        "vite": "6.3.5",
        "vitest": "4.1.4"
    }
}
